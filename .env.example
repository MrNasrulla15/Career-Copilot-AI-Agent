# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Google AI Studio ──────────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# ── Optional: Use Vertex AI instead of AI Studio ──────────────────────────
# Set to "true" if you want to use Google Cloud Vertex AI.
# Requires: gcloud auth application-default login
# Leave as "false" for local development with AI Studio key.
GOOGLE_GENAI_USE_VERTEXAI=false

# ── Model Configuration ────────────────────────────────────────────────────
# Override the default model. Options:
#   gemini-2.5-flash         (latest fast model — default)
#   gemini-2.0-flash         (fast, cost-effective)
#   gemini-1.5-pro           (higher quality, slower, more expensive)
MODEL_NAME=gemini-2.5-flash

# ── Application Settings ───────────────────────────────────────────────────
APP_NAME=career_copilot
LOG_LEVEL=INFO
